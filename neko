def clean_shell_input(text):
    ansi_escape = re.compile(r'\x1B(?:[@-Z\\-_]|\[[0-?]*[ -/]*[@-~])')
    text = ansi_escape.sub('', text)
    text = "".join(char for char in text if char.isprintable() or char in "\n\r\t")
    return text.strip()

